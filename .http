@base = http://localhost:3000

### Get
GET {{base}}/jobs?page=1&limit=50


### 1
POST {{base}}/jobs
Content-Type: application/json

{
  "type": "send_email",
  "priority": 3,
  "payload": {
    "to": "low@test.com",
    "subject": "Low priority"
  }
}

